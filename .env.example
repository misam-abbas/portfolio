# ─────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://misamabbas.dev

# ─────────────────────────────────────────────
# RESEND — contact form email delivery
# Get a key at https://resend.com/api-keys
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL_TO=you@example.com
CONTACT_EMAIL_FROM=Portfolio <contact@misamabbas.dev>

# ─────────────────────────────────────────────
# GEMINI — AI assistant chatbot (free tier available)
# Get a key at https://aistudio.google.com/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────
# GITHUB — used to fetch public repo / contribution data
# Create a classic token (public_repo, read:user scopes) at
# https://github.com/settings/tokens
# ─────────────────────────────────────────────
GITHUB_USERNAME=misam-abbas
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# UPSTASH REDIS — rate limiting for /api/chat and /api/contact
# Create a database at https://console.upstash.com
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
